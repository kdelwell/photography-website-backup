echo "Running pre-commit security checks..."

# Check for secret patterns in staged files
if git diff --cached --diff-filter=ACM | grep -iE '(api[_-]?key|apikey|api[_-]?secret|password|token|secret[_-]?key).*[=:]\s*["\x27][a-zA-Z0-9]{20,}'; then
    echo "ERROR: Potential secret detected in staged files!"
    echo "Move secrets to environment variables."
    exit 1
fi

# Check if .env files are being committed
if git diff --cached --name-only | grep -E '^\.env$|^\.env\.local$|^\.env\.production$'; then
    echo "ERROR: .env file detected in commit!"
    echo "These files should be in .gitignore"
    exit 1
fi

echo "Pre-commit checks passed."
